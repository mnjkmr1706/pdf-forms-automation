# Copy this file to .env or work/.env for local development.
# Never commit real credentials.

# Required only when using GPT-assisted mapping creation.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional Azure Document Intelligence enrichment.
# The current deterministic runtime does not require Azure for production fill,
# but these are the expected variables when Azure-based layout enrichment is enabled.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-document-intelligence-key
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30
